#!/bin/sh
# Stop the DS5Dongle auto-haptics loopback for every active user session.
#
# Invoked by udev (70-ds5dongle.rules, ACTION=="remove") when the DualSense
# dongle is unplugged. The loopback service keeps running with a disconnected
# playback after unplug (node.dont-reconnect prevents feedback), so we stop it
# here to guarantee a fresh re-link the next time the dongle is plugged in.
#
# Runs as root from the udev context; talks to each user's systemd manager.
loginctl list-users --no-legend 2>/dev/null | awk '{print $1}' | while read -r uid; do
    [ "$uid" = "0" ] && continue
    systemctl --user -M "${uid}@" stop ds5-haptics-loopback.service 2>/dev/null || true
done
