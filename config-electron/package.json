{
  "name": "ds5-audio-haptics-bt",
  "version": "0.3.0",
  "private": true,
  "description": "Cross-platform configuration app for DS5 Audio Haptics BT firmware",
  "author": "loteran",
  "productName": "DS5 Audio Haptics BT",
  "license": "MIT",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:linux": "npm run build && CXXFLAGS='-std=c++17' electron-builder --linux",
    "build:win": "npm run build && electron-builder --win nsis",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "node-hid": "^3.2.0",
    "usb": "^2.14.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tabler/icons-react": "^3.44.0",
    "@types/node": "^20.0.0",
    "@types/node-hid": "^1.3.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^35.7.5",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  },
  "allowScripts": {
    "electron@35.7.5": true,
    "esbuild@0.25.12": true,
    "node-hid@3.3.0": true,
    "usb@2.18.0": true
  }
}
